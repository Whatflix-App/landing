---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Whatflix"
  description="Whatflix, the ultimate movie scrolling platform."
>
  <section class="hero">
    <p class="brand">Whatflix</p>
    <h1>the ultimate movie scrolling platform.</h1>
  </section>

  <section class="waitlist-wrap" aria-label="Waitlist signup">
    <form class="waitlist" data-waitlist-form>
      <label class="sr-only" for="email">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder="Email"
        autocomplete="email"
        data-email-input
      />
      <button type="button" data-waitlist-button>Join waitlist</button>
    </form>
  </section>

  <style>
    .hero {
      min-height: calc(100vh - 48px);
      display: grid;
      place-items: start start;
      align-content: start;
      padding: 18vh 12px 32px 20px;
    }

    .brand,
    h1 {
      margin: 0;
    }

    .brand {
      font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 0.96rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: rgba(28, 31, 41, 0.56);
    }

    h1 {
      margin-top: 18px;
      max-width: 11ch;
      font-size: clamp(3rem, 8vw, 6.2rem);
      line-height: 0.94;
      letter-spacing: -0.07em;
      color: #1c1f29;
      text-align: left;
      text-wrap: balance;
    }

    .waitlist-wrap {
      display: flex;
      justify-content: center;
      margin-top: -58vh;
      padding: 0 20px 48px;
      position: relative;
      z-index: 1;
    }

    .waitlist {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      width: auto;
      padding: 0;
      border: 0;
      border-radius: 999px;
      background: transparent;
      backdrop-filter: none;
      transition: width 180ms ease, gap 180ms ease, padding 180ms ease, background-color 180ms ease,
        border-color 180ms ease;
    }

    .waitlist input,
    .waitlist button {
      border: 0;
      background: transparent;
      color: #1c1f29;
      font: inherit;
    }

    .waitlist input {
      flex: 1;
      min-width: 0;
      display: none;
      width: 100%;
      max-width: none;
      padding: 12px 14px;
      font-size: 1rem;
      outline: none;
    }

    .waitlist input::placeholder {
      color: rgba(28, 31, 41, 0.42);
    }

    .waitlist button {
      padding: 12px 20px;
      border-radius: 999px;
      background: #1c1f29;
      color: rgb(247, 245, 240);
      font-family: "SFMono-Regular", SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background-color 160ms ease;
    }

    .waitlist.is-open {
      justify-content: space-between;
      gap: 10px;
      width: min(560px, calc(100vw - 40px));
      padding: 10px;
      border: 1px solid rgba(28, 31, 41, 0.12);
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(10px);
    }

    .waitlist.is-open input {
      display: block;
      max-width: 320px;
    }

    .waitlist.is-open button {
      background: #234436;
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    @media (max-width: 720px) {
      .hero {
        min-height: calc(100vh - 32px);
        padding: 16vh 12px 24px 16px;
      }

      h1 {
        max-width: 9ch;
        font-size: clamp(2.5rem, 14vw, 4.3rem);
      }

      .waitlist {
        flex-direction: column;
        align-items: stretch;
        justify-content: stretch;
        border-radius: 28px;
        width: auto;
      }

      .waitlist.is-open {
        width: min(100%, 420px);
      }

      .waitlist.is-open input {
        max-width: none;
      }

      .waitlist button {
        width: 100%;
      }
    }
  </style>

  <script>
    const form = document.querySelector("[data-waitlist-form]");
    const input = document.querySelector("[data-email-input]");
    const button = document.querySelector("[data-waitlist-button]");

    if (form instanceof HTMLFormElement && input instanceof HTMLInputElement && button instanceof HTMLButtonElement) {
      button.addEventListener("click", () => {
        const isOpen = form.classList.contains("is-open");

        if (!isOpen) {
          form.classList.add("is-open");
          button.textContent = "Send";
          setTimeout(() => {
            input.focus();
          }, 0);
          return;
        }

        if (!input.reportValidity()) {
          return;
        }

        const subject = encodeURIComponent("Whatflix Waitlist");
        const body = encodeURIComponent(`Add me to the Whatflix waitlist: ${input.value}`);
        window.location.href = `mailto:hello@whatflix.app?subject=${subject}&body=${body}`;
      });

      input.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") {
          return;
        }

        event.preventDefault();

        if (!input.reportValidity()) {
          return;
        }

        const subject = encodeURIComponent("Whatflix Waitlist");
        const body = encodeURIComponent(`Add me to the Whatflix waitlist: ${input.value}`);
        window.location.href = `mailto:hello@whatflix.app?subject=${subject}&body=${body}`;
      });
    }
  </script>
</BaseLayout>
